#!/bin/bash
#
# rc.local
#
# This script is executed at the end of each multiuser runlevel.
# Make sure that the script will "exit 0" on success or any other
# value on error.
#
# In order to enable or disable this script just change the execution
# bits.
#
# By default this script does nothing.

# Print the IP address
_IP=$(hostname -I) || true
if [ "$_IP" ]; then
  printf "My IP address is %s\n" "$_IP"
fi

{% if 'k3sserver' in group_names %}# I AM IN GROUP k3sserver{% else %}# I AM NOT IN GROUP k3sserver {% endif +%}
{% if isk3smaster is defined and isk3smaster == true %}# isk3smaster{% else %}# NOT isk3smaster {% endif +%}

# RAN on ansible_hostname={{ ansible_hostname }} inventory_hostname={{ inventory_hostname }}
# check: https://docs.ansible.com/ansible/latest/user_guide/playbooks_vars_facts.html

#/root/ipsetgeoblock.sh
#/root/iptables.sh
#/root/blacklist.sh
#/root/blockbadhosts_ipset.sh

{%+ if 'k3sserver' in group_names %}
/usr/sbin/ipset restore </root/ipset.save
/usr/sbin/ip6tables-restore -v /root/ip6tables.save
(echo rc.local iptablestuff START $(date); /root/iptables.sh ; /root/ipsetgeoblock.sh ; /root/blacklist.sh ; /root/blockbadhosts_ipset.sh; echo rc.local iptablestuff END $(date)) 1>>/tmp/iptables_rc_local.log 2>&1  &
{%+ else +%}
/usr/sbin/ipset restore </root/ipset.save
/usr/sbin/iptables-restore -v /root/iptables.save
/usr/sbin/ip6tables-restore -v /root/ip6tables.save
{%+ endif +%}

exit 0
