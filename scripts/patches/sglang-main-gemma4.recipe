#
# Custom recipe: SGLang main (pinned to PR #22079 merge) + Gemma-4 NVFP4 patches.
#
# Based on sglang-0.5.10-sm121.recipe but uses a main-branch commit instead
# of the v0.5.10 tag. This includes native Gemma-4 support (PR #21952, merged
# 2026-04-07) and the NVFP4 fix (PR #22079, merged 2026-04-10).
#
# Two additional patches are applied on top (not yet merged upstream):
#   - sglang-gemma4-nvfp4-expert-loading.patch (PR #22929) — per-expert
#     NVFP4 weight loading for Gemma-4 MoE
#   - sglang-gemma4-geglu-nan-clamp.patch (PR #22928) — GEGLU activation
#     for cutlass_moe_fp4 + FP4 block scale NaN clamp on SM120/121
#
# Both patches apply cleanly to the pinned commit (verified via dry-run).
#
# See SGLANG_GEMMA4_UPSTREAM_BUG.md for the full root cause analysis.
#
DOCKERFILE=Dockerfile.sglang-nightly
TARGET=runtime

BASE_IMAGE=xomoxcc/dgx-spark-pytorch-dev:2.11.0-v1-cu132

FLASHINFER_VERSION=0.6.7.post3
TRANSFORMERS_VERSION=5.5.3

# Pin to the merge commit of PR #22079 ([nvidia] Gemma4 nvfp4 fix).
# This is the latest Gemma-4-relevant commit in main. Native Gemma-4
# support (PR #21952) is included. SGLANG_VERSION is left empty so
# setuptools-scm derives the version from the git history.
SGLANG_VERSION=
SGLANG_REF="5638d40f3a31a338edb1a708decee16915af0565"

IMAGE_TAG=xomoxcc/dgx-spark-sglang:main-gemma4-sm121
